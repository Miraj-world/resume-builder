{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://resume-builder.local/schemas/career-fact.schema.json",
  "title": "Career Fact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "workspaceId",
    "subject",
    "predicate",
    "value",
    "evidenceType",
    "riskLevel",
    "verificationStatus",
    "eligibility",
    "confidence",
    "evidence"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "id": { "type": "string", "minLength": 1 },
    "workspaceId": { "type": "string", "minLength": 1 },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id"],
      "properties": {
        "type": {
          "enum": [
            "person",
            "experience",
            "project",
            "education",
            "credential",
            "achievement",
            "skill",
            "organization"
          ]
        },
        "id": { "type": "string", "minLength": 1 }
      }
    },
    "predicate": { "type": "string", "minLength": 1 },
    "value": true,
    "evidenceType": { "enum": ["observed", "user_stated", "inferred"] },
    "riskLevel": { "enum": ["low", "medium", "high"] },
    "verificationStatus": {
      "enum": [
        "auto_accepted",
        "pending_review",
        "user_verified",
        "rejected",
        "superseded",
        "in_conflict"
      ]
    },
    "eligibility": {
      "enum": ["eligible", "guidance_only", "sensitive", "excluded"]
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "https://resume-builder.local/schemas/evidence-reference.schema.json"
      }
    }
  }
}
