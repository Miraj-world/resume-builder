{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://resume-builder.local/schemas/project-summary.schema.json",
  "title": "Project Summary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "projectId",
    "workspaceId",
    "source",
    "overview",
    "technologies",
    "components",
    "features",
    "qualitySignals",
    "candidateInferences",
    "warnings",
    "privacy"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "projectId": { "type": "string", "minLength": 1 },
    "workspaceId": { "type": "string", "minLength": 1 },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "analysisMethod", "revision", "analyzedAt"],
      "properties": {
        "kind": { "enum": ["local_companion", "github_repository", "repository_upload"] },
        "analysisMethod": { "enum": ["local_static", "cloud_static"] },
        "revision": { "type": "string", "minLength": 1 },
        "analyzedAt": { "type": "string", "format": "date-time" }
      }
    },
    "overview": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "description", "status"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 160 },
        "description": { "type": "string", "maxLength": 2000 },
        "status": { "enum": ["active", "archived", "unknown"] }
      }
    },
    "technologies": {
      "type": "array",
      "items": { "$ref": "#/$defs/signal" }
    },
    "components": {
      "type": "array",
      "items": { "$ref": "#/$defs/namedItem" }
    },
    "features": {
      "type": "array",
      "items": { "$ref": "#/$defs/namedItem" }
    },
    "qualitySignals": {
      "type": "array",
      "items": { "$ref": "#/$defs/signal" }
    },
    "candidateInferences": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["claim", "riskLevel", "verificationStatus", "confidence"],
        "properties": {
          "claim": { "type": "string", "minLength": 1, "maxLength": 1000 },
          "riskLevel": { "enum": ["medium", "high"] },
          "verificationStatus": { "const": "pending_review" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string", "maxLength": 500 }
    },
    "exclusions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ignoredFileCount": { "type": "integer", "minimum": 0 },
        "secretCandidateCount": { "type": "integer", "minimum": 0 },
        "binaryFileCount": { "type": "integer", "minimum": 0 }
      }
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rawSourceUploaded", "containsAbsolutePaths", "containsSecretValues"],
      "properties": {
        "rawSourceUploaded": { "const": false },
        "containsAbsolutePaths": { "const": false },
        "containsSecretValues": { "const": false }
      }
    }
  },
  "$defs": {
    "namedItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "description", "confidence"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 160 },
        "description": { "type": "string", "maxLength": 1000 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "signal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "confidence", "riskLevel", "evidence"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 160 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "riskLevel": { "enum": ["low", "medium"] },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "https://resume-builder.local/schemas/evidence-reference.schema.json"
          }
        }
      }
    }
  }
}
