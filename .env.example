# Local development creates a database-backed local session automatically.
AUTH_MODE=local_development

# Production uses a real PostgreSQL connection and must not enable the local
# development session endpoint.
# DATABASE_URL=postgresql://user:password@127.0.0.1:5432/resume_builder
# AUTH_MODE=external_oidc

# Optional zero-config local database location. The default is data/postgres.
# RESUME_BUILDER_DATA_DIR=D:\path\to\resume-builder-data
